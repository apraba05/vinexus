{
  "name": "vinexus",
  "version": "1.0.39",
  "productName": "Vinexus",
  "description": "Desktop IDE for managing and editing code on virtual machines",
  "homepage": "https://vinexus.space",
  "repository": {
    "type": "git",
    "url": "https://github.com/apraba05/vinexus.git"
  },
  "author": {
    "name": "Vinexus",
    "email": "support@vinexus.space"
  },
  "private": true,
  "main": "electron/main.js",
  "build": {
    "appId": "com.vinexus.ide",
    "productName": "Vinexus",
    "copyright": "Copyright © 2025 Vinexus",
    "asar": false,
    "directories": {
      "output": "dist-electron",
      "buildResources": "electron/assets"
    },
    "files": [
      "electron/**/*",
      "frontend/.next/standalone/**/*",
      "backend/dist/**/*",
      "backend/node_modules/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*",
      "node_modules/ssh2/**/*"
    ],
    "extraResources": [
      {
        "from": "frontend/.next/standalone/node_modules",
        "to": "app/frontend/.next/standalone/node_modules"
      },
      {
        "from": "backend/prisma-runtime",
        "to": "app/backend/node_modules/.prisma"
      }
    ],
    "mac": {
      "icon": "electron/assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "gatekeeperAssess": false,
      "artifactName": "Vinexus-mac.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "protocols": [
        {
          "name": "Vinexus",
          "schemes": [
            "vinexus"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Vinexus ${version}",
      "iconSize": 80,
      "contents": [
        {
          "x": 410,
          "y": 200,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 130,
          "y": 200,
          "type": "file"
        }
      ]
    },
    "win": {
      "icon": "electron/assets/icon.ico",
      "artifactName": "Vinexus-Setup-win.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "protocols": [
        {
          "name": "Vinexus",
          "schemes": [
            "vinexus"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vinexus"
    },
    "linux": {
      "icon": "electron/assets/icon.png",
      "category": "Development",
      "artifactName": "Vinexus-linux.${ext}",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "protocols": [
        {
          "name": "Vinexus",
          "schemes": [
            "vinexus"
          ]
        }
      ]
    },
    "deb": {
      "depends": [
        "libnotify4",
        "libxtst6",
        "libnss3"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "apraba05",
      "repo": "vinexus",
      "releaseType": "release"
    }
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "web:dev": "cd frontend && npm run dev",
    "api:dev": "cd backend && npm run dev",
    "desktop:open": "wait-on tcp:3000 tcp:4000 && electron .",
    "desktop:dev": "concurrently --kill-others --names \"NEXT,EXPRESS,ELECTRON\" --prefix-colors \"cyan,yellow,magenta\" \"npm run web:dev\" \"npm run api:dev\" \"npm run desktop:open\"",
    "frontend:dev": "cd frontend && npm run dev",
    "backend:dev": "cd backend && npm run dev",
    "electron:dev": "npm run desktop:dev",
    "frontend:build": "cd frontend && npm run build",
    "backend:build": "cd backend && npm run build",
    "desktop:runtime-env": "node scripts/write-runtime-env.js",
    "electron:build": "npm run frontend:build && npm run desktop:runtime-env && npm run backend:build && electron-builder",
    "electron:build:mac": "npm run frontend:build && npm run desktop:runtime-env && npm run backend:build && electron-builder --mac",
    "electron:build:win": "npm run frontend:build && npm run desktop:runtime-env && npm run backend:build && electron-builder --win",
    "electron:build:linux": "npm run frontend:build && npm run desktop:runtime-env && npm run backend:build && electron-builder --linux",
    "rebuild-native": "electron-rebuild -f -w node-pty"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-ec2": "3.1012.0",
    "@prisma/client": "6.19.2",
    "bcryptjs": "^3.0.3",
    "electron-log": "5.4.3",
    "electron-store": "8.2.0",
    "electron-updater": "6.8.3",
    "node-pty": "1.1.0",
    "ssh2": "1.17.0",
    "uuid": "10.0.0"
  },
  "devDependencies": {
    "concurrently": "9.2.1",
    "electron": "41.0.3",
    "electron-builder": "26.8.1",
    "electron-rebuild": "3.2.9",
    "prisma": "^6.19.2",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "wait-on": "9.0.4"
  }
}
