# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vmide?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# OAuth — GitHub (optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""


# Stripe (optional — not needed for admin-granted subscriptions)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# Stripe price IDs — one per plan × billing cycle (copy from Stripe Dashboard > Products)
STRIPE_PREMIUM_MONTHLY_PRICE_ID=""
STRIPE_PREMIUM_ANNUAL_PRICE_ID=""
STRIPE_MAX_MONTHLY_PRICE_ID=""
STRIPE_MAX_ANNUAL_PRICE_ID=""
STRIPE_AIPRO_MONTHLY_PRICE_ID=""
STRIPE_AIPRO_ANNUAL_PRICE_ID=""

# Resend (email)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@vinexus.space"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Analytics
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
